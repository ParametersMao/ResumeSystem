      "customCss": `
        /* 测试自定义CSS是否生效 - 这些样式应该很明显 */
        .dynamic-resume-preview {
          border: 5px solid red !important;
          background: linear-gradient(45deg, #ff6b6b, #4ecdc4) !important;
        }
        
        .resume-content {
          background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%) !important;
          min-height: 100vh;
          border: 3px solid blue !important;
          border-radius: 20px !important;
        }
        
        .skill-tag:hover {
          transform: translateY(-5px);
          box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .custom-experience h3 {
          color: white !important;
          border-bottom: 2px solid white;
          padding-bottom: 10px;
        }
        
        .custom-experience .timeline-item {
          background: rgba(255,255,255,0.1);
          padding: 15px;
          border-radius: 10px;
          margin-bottom: 15px;
        }
        
        /* 测试CSS变量是否生效 */
        .test-token-class {
          color: var(--colors-primary, #3498db);
          font-size: var(--spacing-lg, 24px);
        }
      `,
      "tokens": {
        "spacing": {
          "xs": "4px",
          "sm": "8px",
          "md": "16px",
          "lg": "24px",
          "xl": "32px"
        },
        "colors": {
          "primary": "#667eea",
          "secondary": "#764ba2",
          "accent": "#f093fb"
        },
        "typography": {
          "fontSize": {
            "h1": "48px",
            "h2": "32px",
            "body": "16px"
          }
        }
      }
    },
    "responsive": {
      "breakpoints": {
        "mobile": "0px",
        "tablet": "768px",
        "desktop": "1024px"
      },
      "mobile": {
        ".skill-tag": {
          "fontSize": "14px",
          "padding": "8px 16px"
        },
        ".hero-section": {
          "flexDirection": "column",
          "textAlign": "center"
        }
      },
      "tablet": {
        ".skill-tag": {
          "fontSize": "16px",
          "padding": "10px 20px"
        }
      },
      "desktop": {
        ".skill-tag": {
          "fontSize": "18px",
          "padding": "12px 24px"
        }
      }
    }
