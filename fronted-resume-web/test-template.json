        "config": {
          "customClass": "custom-experience",
          "customStyle": {
            "background": "linear-gradient(45deg, #f093fb 0%, #f5576c 100%)",
            "color": "white",
            "padding": "30px",
            "borderRadius": "15px",
            "boxShadow": "0 10px 30px rgba(0,0,0,0.3)"
