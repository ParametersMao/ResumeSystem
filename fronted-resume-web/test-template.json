                }
              },
              {
                "type": "text",
                "content": "React",
                "className": "skill-tag",
                "style": {
                  "background": "#61dafb",
                  "color": "white",
                  "padding": "10px 20px",
                  "borderRadius": "25px",
                  "textAlign": "center",
                  "fontWeight": "600",
                  "transition": "transform 0.2s ease"
                }
              },
              {
                "type": "text",
                "content": "TypeScript",
                "className": "skill-tag",
                "style": {
                  "background": "#3178c6",
                  "color": "white",
                  "padding": "10px 20px",
                  "borderRadius": "25px",
                  "textAlign": "center",
                  "fontWeight": "600",
                  "transition": "transform 0.2s ease"
