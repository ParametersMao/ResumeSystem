NODE_ENV=production
PORT=3000

# Comma-separated allowed origins for browser access.
FRONTEND_URL=https://www.your-domain.com,https://admin.your-domain.com

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=resume_app
DB_PASSWORD=replace-me
DB_DATABASE=resume_system

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# AI provider
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Cloudflare R2 object storage
# Endpoint should be account-level, without the bucket path.
R2_ENDPOINT=https://2cef367ed0d9606a47029b9aa51fa19c.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=cv-assets
R2_PUBLIC_BASE_URL=https://pub-3849403bf41741939821877a7df073c5.r2.dev

# Puppeteer browser path on Linux server
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
