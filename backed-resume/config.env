# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=123456
DB_DATABASE=resume_system

# JWT 配置（生产环境通过环境变量覆盖）
# JWT_ACCESS_SECRET: access_token 签名密钥（运行时必须注入）
# JWT_REFRESH_SECRET: refresh_token 签名密钥（运行时必须注入）
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 应用配置
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173,http://localhost:3030

# AI API 配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_URL=https://api.openai.com/v1

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
