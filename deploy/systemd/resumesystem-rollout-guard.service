[Unit]
Description=Fail-close incomplete ResumeSystem rollout before Docker
DefaultDependencies=no
Wants=network-online.target
After=local-fs.target network-online.target
Before=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/resumesystem-rollout-guard --firewall-only
User=root
Group=root

[Install]
RequiredBy=docker.service
