# Copy to `.env` on the server and replace every secret before starting.

COMPOSE_PROJECT_NAME=resumesystem
# Release images are built on a separate linux/amd64 builder, transferred as a
# checksummed docker-save archive, and loaded on the server. Production rollout
# always uses `up --no-build`; replace these with the exact vX.Y.Z-<12-sha> tags.
RELEASE_COMMIT=replace-with-full-40-character-git-commit
RELEASE_ARTIFACT_MANIFEST=/opt/resumesystem-artifacts/replace-with-release-manifest.json
RELEASE_ARTIFACT_CHECKSUMS=/opt/resumesystem-artifacts/replace-with-release-SHA256SUMS
MYSQL_IMAGE=resumesystem_mysql:v1.3.4-replace12sha
BACKEND_IMAGE=resumesystem_backend:v1.3.4-replace12sha
WEB_IMAGE=resumesystem_web:v1.3.4-replace12sha
ADMIN_IMAGE=resumesystem_admin:v1.3.4-replace12sha
NGINX_IMAGE=resumesystem_nginx:v1.3.4-replace12sha
AGENT_IMAGE=resumesystem_agent:v1.3.4-replace12sha
QDRANT_IMAGE=resumesystem_qdrant:v1.3.4-replace12sha

# Optional Debian mirror for faster backend image builds in mainland China.
DEBIAN_MIRROR=https://mirrors.aliyun.com
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

HTTP_PORT=80
HTTPS_PORT=443
# Add every browser origin explicitly, including its scheme. HTTP and HTTPS on the
# same host are different origins; keep the temporary public-IP entry until the
# domain HTTPS path has passed external acceptance testing.
FRONTEND_URL=https://aidana.top,https://www.aidana.top,https://admin.aidana.top,http://aidana.top,http://www.aidana.top,http://admin.aidana.top,http://121.43.208.184,https://121.43.208.184
CORS_PROBE_ORIGIN=http://121.43.208.184
# Temporary IP-only acceptance mode. Change to true only after the public domain
# and certificate pass checks from an independent external network.
REQUIRE_PUBLIC_HTTPS=false
# One-time migration escape hatch only when the linked pre-v1.3.4 release had no
# real RAG. Keep false after v1.3.4 has passed production acceptance.
ALLOW_PRE_RAG_BACKUP=false

MYSQL_ROOT_PASSWORD=replace-with-long-random-root-password
DB_DATABASE=resume_system
DB_USERNAME=resume_app
DB_PASSWORD=replace-with-long-random-db-password

JWT_ACCESS_SECRET=replace-with-long-random-jwt-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-jwt-refresh-secret
SYSTEM_CONFIG_MASTER_KEY=replace-with-a-base64-encoded-32-byte-key
# Optional first-run bootstrap only. Set both once, verify login, then remove them.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_CODE_SECRET=replace-with-long-random-email-code-secret
EMAIL_ALLOW_DEV_CODE=false

AI_ENABLED=true
AI_PROVIDER=deepseek
AI_EXECUTION_ENGINE=agent
OPENAI_API_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-v4-pro

# Required by compose even when the rag profile is not enabled.
AGENT_INTERNAL_SECRET=replace-with-long-random-agent-secret
AGENT_EXECUTION_MODE=live
AGENT_SERVICE_URL=http://agent:8000
AGENT_REQUEST_TIMEOUT_MS=150000
KNOWLEDGE_AGENT_REQUEST_TIMEOUT_MS=300000
LLM_TIMEOUT_SECONDS=120
RAG_ENABLED=true
RAG_MIN_SCORE=0.35
RAG_CANDIDATE_LIMIT=120
RAG_DENSE_WEIGHT=0.68
RAG_LEXICAL_WEIGHT=0.27
RAG_STRICT_SOURCES=true
# Agent lifespan preloads FastEmbed before serving traffic. The release probe
# then verifies one real cross-store retrieval within this bounded budget.
RAG_HEALTH_PROBE_TIMEOUT_SECONDS=60
RAG_HEALTH_PROBE_ATTEMPTS=1
QDRANT_COLLECTION=resume_knowledge_bge_zh_v1_5
QDRANT_API_KEY=
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Optional object storage. Leave empty for local upload volume in MVP.
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
