# Copy this file to .env before running docker compose.

MYSQL_ROOT_PASSWORD=change-me-root
DB_USERNAME=resume_app
DB_PASSWORD=change-me-db
DB_DATABASE=resume_system

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173,http://localhost:3030

WEB_PORT=5173
ADMIN_PORT=3030
BACKEND_PORT=3000
MYSQL_PORT=3306

# Optional: AI provider. The system can still run with the mock provider before real API setup.
OPENAI_API_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional: Cloudflare R2. Keep real keys only in local/server .env, never commit them.
R2_ENDPOINT=https://2cef367ed0d9606a47029b9aa51fa19c.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cv-assets
R2_PUBLIC_BASE_URL=https://pub-3849403bf41741939821877a7df073c5.r2.dev

