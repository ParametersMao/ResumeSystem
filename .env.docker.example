# Copy this file to .env before running docker compose.

MYSQL_ROOT_PASSWORD=change-me-root
# Optional; leave blank outside mainland China.
DEBIAN_MIRROR=
DB_USERNAME=resume_app
DB_PASSWORD=change-me-db
DB_DATABASE=resume_system

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
SYSTEM_CONFIG_MASTER_KEY=replace-with-a-base64-encoded-32-byte-key
# Optional first-run bootstrap only; remove both values after the first successful login.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_CODE_SECRET=replace-with-a-third-long-random-string
# Local acceptance only. Keep false in production after SMTP is configured.
EMAIL_ALLOW_DEV_CODE=false

FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3030,http://127.0.0.1:3030

WEB_PORT=5173
ADMIN_PORT=3030
BACKEND_PORT=3000
MYSQL_PORT=3306
AGENT_PORT=18000
AGENT_EXECUTION_MODE=live
AGENT_INTERNAL_SECRET=replace-with-a-long-random-agent-secret
QDRANT_PORT=16333
# Local full-version profile: `docker compose --profile rag up -d`.
RAG_ENABLED=true
RAG_MIN_SCORE=0.35
RAG_CANDIDATE_LIMIT=120
RAG_DENSE_WEIGHT=0.68
RAG_LEXICAL_WEIGHT=0.27
RAG_STRICT_SOURCES=true
QDRANT_COLLECTION=resume_knowledge_bge_zh_v1_5
QDRANT_API_KEY=
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Optional: AI provider. The full stack routes DeepSeek through the RAG Agent.
AI_ENABLED=true
AI_PROVIDER=deepseek
AI_EXECUTION_ENGINE=agent
OPENAI_API_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-v4-pro
AGENT_SERVICE_URL=http://agent:8000

# Optional: Cloudflare R2. Keep real keys only in local/server .env, never commit them.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=<bucket-name>
R2_PUBLIC_BASE_URL=https://<public-bucket-domain>
