{
  "editor": {
    "formatOnSave": true,
    "formatOnPaste": false,
    "insertSpaces": true,
    "tabSize": 2,
    "detectIndentation": true,
    "autoClosingBrackets": true,
    "autoIndent": true,
    "insertFinalNewline": true
  },
  "vue": {
    "validation": {
      "template": true,
      "style": true,
      "script": true
    },
    "format": {
      "defaultFormatter": {
        "js": "prettier",
        "ts": "prettier"
      }
    },
    "completion": {
      "autoImport": true,
      "useScaffoldSnippets": true
    }
  },
  "typescript": {
    "validate": true,
    "format": {
      "semicolons": true,
      "singleQuote": true,
      "trailingComma": "none",
      "arrowParens": "always"
    },
    "preferences": {
      "quoteStyle": "single",
      "importModuleSpecifier": "non-relative"
    }
  },
  "javascript": {
    "validate": true,
    "format": {
      "semicolons": true,
      "singleQuote": true,
      "trailingComma": "none"
    }
  },
  "css": {
    "validate": true,
    "lint": {
      "compatibleVendorPrefixes": "warning",
      "vendorPrefix": "warning",
      "duplicateProperties": "warning",
      "emptyRules": "warning"
    }
  },
  "html": {
    "format": {
      "wrapLineLength": 100,
      "wrapAttributes": "auto"
    },
    "validate": true
  },
  "files": {
    "watcherExclude": {
      "**/node_modules/**": true,
      "**/dist/**": true
    },
    "exclude": [
      "node_modules",
      "dist",
      ".git",
      ".vscode"
    ]
  },
  "search": {
    "exclude": {
      "**/node_modules": true,
      "**/dist": true
    }
  },
  "explorer": {
    "sortOrder": "type",
    "exclude": [
      "node_modules",
      "dist",
      ".git",
      ".vscode"
    ]
  },
  "git": {
    "autofetch": true,
    "confirmSync": true,
    "enableSmartCommit": true
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none",
    "arrowParens": "always",
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  },
  "eslint": {
    "run": "onSave",
    "enable": true
  },
  "terminal": {
    "integrated": {
      "fontFamily": "Consolas, '微软雅黑', monospace",
      "fontSize": 12,
      "lineHeight": 1.2
    }
  },
  "language": {
    "chinese": {
      "locale": "zh-CN",
      "enabled": true
    }
  }
} 